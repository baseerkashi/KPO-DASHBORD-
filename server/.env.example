# OpenAI API key (required for live AI insights — get one at https://platform.openai.com/api-keys )
OPENAI_API_KEY=your_openai_api_key_here

# Optional: model name (default in code is gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Server port (default 5001 — avoids common “port 5000 already in use” on Windows)
PORT=5001
